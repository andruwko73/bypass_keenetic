#  echo "server=/$line/8.8.8.8" >> /opt/etc/unblock.dnsmasq
#done < /opt/etc/unblock/shadowsocks.txt


while read -r line || [ -n "$line" ]; do
  write_route_domain vmess "$line" unblockvmess unblockvmessudp bypass_call_signal_vmess 0
done < "$UNBLOCK_DIR/vmess.txt"


while read -r line || [ -n "$line" ]; do
  write_route_domain vless "$line" unblockvless unblockvlessudp bypass_call_signal_vless 0
done < "$UNBLOCK_DIR/vless.txt"


while read -r line || [ -n "$line" ]; do
  write_route_domain vless2 "$line" unblockvless2 unblockvless2udp bypass_call_signal_vless2 0
done < "$UNBLOCK_DIR/vless-2.txt"


while read -r line || [ -n "$line" ]; do
  write_route_domain trojan "$line" unblocktroj unblocktrojudp bypass_call_signal_troj 0
done < "$UNBLOCK_DIR/trojan.txt"

append_youtube_priority_domains
dedupe_dnsmasq_output

