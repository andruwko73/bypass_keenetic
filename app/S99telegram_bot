#!/bin/sh

BOT_DIR="/opt/etc/bot"
MAIN_SCRIPT="$BOT_DIR/main.py"
LOG_FILE="$BOT_DIR/error.log"
BOT_CONFIG_PATH="$BOT_DIR/bot_config.py"
LEGACY_CONFIG_PATH="/opt/etc/bot_config.py"
INSTALLER_SERVICE_PATH="/opt/etc/init.d/S98telegram_bot_installer"
SERVICE_LOCK_DIR="/tmp/bypass_telegram_bot_service.lock"
SERVICE_LOCK_HELD=0

release_service_lock() {
    if [ "$SERVICE_LOCK_HELD" = "1" ]; then
        rm -rf "$SERVICE_LOCK_DIR" 2>/dev/null || true
        SERVICE_LOCK_HELD=0
    fi
}

acquire_service_lock() {
    if [ "${BYPASS_BOT_SERVICE_LOCKED:-0}" = "1" ]; then
        return 0
    fi
    attempts=0
    while ! mkdir "$SERVICE_LOCK_DIR" 2>/dev/null; do
        lock_pid=""
        [ -f "$SERVICE_LOCK_DIR/pid" ] && lock_pid=$(cat "$SERVICE_LOCK_DIR/pid" 2>/dev/null || true)
        if [ -n "$lock_pid" ] && [ ! -d "/proc/$lock_pid" ]; then
            rm -rf "$SERVICE_LOCK_DIR" 2>/dev/null || true
            continue
        fi
        attempts=$((attempts + 1))
        if [ "$attempts" -ge 60 ]; then
            echo "Error: timed out waiting for bot service lock"
            exit 1
        fi
        sleep 1
    done
    SERVICE_LOCK_HELD=1
    echo "$$" > "$SERVICE_LOCK_DIR/pid" 2>/dev/null || true
    export BYPASS_BOT_SERVICE_LOCKED=1
    trap release_service_lock EXIT INT TERM
}

cleanup_python_bytecode() {
    if [ -d "$BOT_DIR" ]; then
        find "$BOT_DIR" -type d -name "__pycache__" -prune -exec rm -rf {} + 2>/dev/null || true
    fi
    rm -rf /opt/etc/__pycache__ /opt/root/__pycache__ 2>/dev/null || true
}

trim_log_file() {
    path="$1"
    max_bytes="$2"
    [ -f "$path" ] || return 0
    size=$(wc -c < "$path" 2>/dev/null || echo 0)
    [ "$size" -gt "$max_bytes" ] 2>/dev/null || return 0
    tmp_path="${path}.tmp.$$"
    tail -c "$max_bytes" "$path" > "$tmp_path" 2>/dev/null && cat "$tmp_path" > "$path"
    rm -f "$tmp_path" 2>/dev/null || true
}

trim_runtime_logs() {
    trim_log_file "$LOG_FILE" 262144
    trim_log_file /opt/etc/error.log 262144
    trim_log_file /opt/etc/xray/error.log 524288
    trim_log_file /opt/etc/xray/access.log 262144
    trim_log_file /opt/etc/v2ray/error.log 524288
    trim_log_file /opt/etc/v2ray/access.log 262144
}

check_process() {
    found=0
    for proc in /proc/[0-9]*; do
        [ -r "$proc/cmdline" ] || continue
        exe=$(readlink "$proc/exe" 2>/dev/null || true)
        case "$exe" in
            *python3*)
                if grep -qa "$MAIN_SCRIPT" "$proc/cmdline"; then
                    echo "${proc##*/}"
                    found=1
                fi
                ;;
        esac
    done
    [ "$found" = "1" ] || return 1
}

has_running_process() {
    check_process >/dev/null 2>&1
}

cleanup_pool_probe_runtime() {
    for pid in $(pgrep -f "/tmp/bypass_pool_probe_" 2>/dev/null); do
        kill "$pid" >/dev/null 2>&1 || true
    done
    sleep 1
    for pid in $(pgrep -f "/tmp/bypass_pool_probe_" 2>/dev/null); do
        kill -9 "$pid" >/dev/null 2>&1 || true
    done
    rm -f /tmp/bypass_pool_probe_*.json 2>/dev/null || true
}

has_config() {
    config_path=""
    [ -f "$BOT_CONFIG_PATH" ] && config_path="$BOT_CONFIG_PATH"
    [ -z "$config_path" ] && [ -f "$LEGACY_CONFIG_PATH" ] && config_path="$LEGACY_CONFIG_PATH"
    [ -n "$config_path" ] || return 1
    grep -q "^token[[:space:]]*=" "$config_path" || return 1
    grep -q "^usernames[[:space:]]*=" "$config_path" || return 1
}

migrate_youtube_edge_prefetch_config() {
    config_path=""
    [ -f "$BOT_CONFIG_PATH" ] && config_path="$BOT_CONFIG_PATH"
    [ -z "$config_path" ] && [ -f "$LEGACY_CONFIG_PATH" ] && config_path="$LEGACY_CONFIG_PATH"
    [ -n "$config_path" ] || return 0

    if grep -Eq '^youtube_edge_prefetch_interval_seconds[[:space:]]*=[[:space:]]*0([[:space:]#]|$)' "$config_path"; then
        sed -i 's/^youtube_edge_prefetch_interval_seconds[[:space:]]*=.*/youtube_edge_prefetch_interval_seconds = 7200/' "$config_path" || true
    elif ! grep -Eq '^youtube_edge_prefetch_interval_seconds[[:space:]]*=' "$config_path"; then
        printf '\nyoutube_edge_prefetch_interval_seconds = 7200\n' >> "$config_path"
    fi

    grep -Eq '^youtube_edge_prefetch_cache_restore_min_candidates[[:space:]]*=' "$config_path" || \
        printf '\nyoutube_edge_prefetch_cache_restore_min_candidates = 8\n' >> "$config_path"
    grep -Eq '^youtube_edge_prefetch_cache_restore_max_age_seconds[[:space:]]*=' "$config_path" || \
        printf 'youtube_edge_prefetch_cache_restore_max_age_seconds = 21600\n' >> "$config_path"
}

stop_main_process() {
    cleanup_pool_probe_runtime
    pids=$(check_process)
    if [ -z "$pids" ]; then
        return 0
    fi

    for pid in $pids; do
        kill "$pid" >/dev/null 2>&1 || true
    done

    attempts=0
    while has_running_process && [ "$attempts" -lt 15 ]; do
        sleep 1
        attempts=$((attempts + 1))
    done

    if has_running_process; then
        pids=$(check_process)
        for pid in $pids; do
            kill -9 "$pid" >/dev/null 2>&1 || true
        done
        sleep 1
        if has_running_process; then
            echo "Error: Bot failed to stop even with SIGKILL"
            exit 1
        fi
    fi
    cleanup_pool_probe_runtime
    return 0
}

start_installer_instead() {
    if [ ! -x "$INSTALLER_SERVICE_PATH" ]; then
        echo "Error: bot_config.py not found and installer service is unavailable"
        exit 1
    fi

    stop_main_process
    "$INSTALLER_SERVICE_PATH" start
}

case "$1" in
    start)
        acquire_service_lock
        if ! has_config; then
            echo "bot_config.py not found, starting installer instead"
            start_installer_instead
            exit $?
        fi

        migrate_youtube_edge_prefetch_config

        if has_running_process; then
            echo "Bot is already running"
            exit 0
        fi

        cleanup_python_bytecode
        trim_runtime_logs
        unset BYPASS_KEENETIC_COMMAND_WORKER
        MALLOC_ARENA_MAX="${MALLOC_ARENA_MAX:-1}" \
        MALLOC_TRIM_THRESHOLD_="${MALLOC_TRIM_THRESHOLD_:-262144}" \
        PYTHONDONTWRITEBYTECODE=1 python3 "$MAIN_SCRIPT" >> "$LOG_FILE" 2>&1 &
        pid=$!
        sleep 2

        if has_running_process; then
            echo "Bot started successfully (PID: $pid)"
            exit 0
        fi

        echo "Error: Bot failed to start"
        exit 1
        ;;
    stop)
        acquire_service_lock
        if ! has_config; then
            stop_main_process
            if [ -x "$INSTALLER_SERVICE_PATH" ]; then
                "$INSTALLER_SERVICE_PATH" stop
                exit 0
            fi
            echo "Bot is not running"
            exit 0
        fi

        if ! has_running_process; then
            echo "Bot is not running"
            exit 0
        fi

        stop_main_process
        echo "Bot stopped successfully"
        exit 0
        ;;
    restart)
        acquire_service_lock
        if ! has_config; then
            if [ -x "$INSTALLER_SERVICE_PATH" ]; then
                "$INSTALLER_SERVICE_PATH" stop >/dev/null 2>&1 || true
                start_installer_instead
                exit $?
            fi
            echo "Error: bot_config.py not found and installer service is unavailable"
            exit 1
        fi

        "$0" stop
        sleep 1
        "$0" start
        ;;
    status)
        if ! has_config; then
            if [ -x "$INSTALLER_SERVICE_PATH" ]; then
                echo "bot_config.py not found, installer mode is active"
                "$INSTALLER_SERVICE_PATH" status
                exit 0
            fi
            echo "bot_config.py not found, installer service is unavailable"
            exit 1
        fi

        pid=$(check_process)
        if [ -n "$pid" ]; then
            echo "Bot is running (PID: $pid)"
        else
            echo "Bot is stopped"
        fi
        exit 0
        ;;
    *)
        echo "Usage: $0 {start|stop|restart|status}"
        exit 1
        ;;
esac
