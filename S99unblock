#!/bin/sh

PATH="/opt/sbin:/opt/bin:/usr/sbin:/usr/bin:/sbin:/bin${PATH:+:$PATH}"
export PATH

PID_FILE="${BYPASS_UNBLOCK_REFRESH_PID_FILE:-/opt/var/run/bypass-unblock-scheduler.pid}"
INTERVAL_SECONDS="${BYPASS_UNBLOCK_REFRESH_INTERVAL_SECONDS:-900}"
DNSMASQ_INTERVAL_SECONDS="${BYPASS_UNBLOCK_DNSMASQ_REFRESH_INTERVAL_SECONDS:-3600}"
NDNPROXY_INTERVAL_SECONDS="${BYPASS_UNBLOCK_NDNPROXY_REFRESH_INTERVAL_SECONDS:-$INTERVAL_SECONDS}"
REFRESH_CHECK_INTERVAL_SECONDS="${BYPASS_UNBLOCK_REFRESH_CHECK_INTERVAL_SECONDS:-60}"
DEDUP_INTERVAL_SECONDS="${BYPASS_RUNTIME_DEDUPE_INTERVAL_SECONDS:-60}"
DEDUP_LOCK_STALE_SECONDS="${BYPASS_RUNTIME_DEDUPE_LOCK_STALE_SECONDS:-120}"
DEDUP_FORCE_INTERVAL_SECONDS="${BYPASS_RUNTIME_DEDUPE_FORCE_INTERVAL_SECONDS:-900}"
PRIORITY_REFRESH_INTERVAL_SECONDS="${BYPASS_VLESS_PRIORITY_REFRESH_INTERVAL_SECONDS:-900}"
LOG_FILE="${BYPASS_UNBLOCK_REFRESH_LOG:-/opt/var/log/bypass-unblock-scheduler.log}"
UNBLOCK_DIR="${UNBLOCK_DIR:-/opt/etc/unblock}"
DNS_HOST="${DNS_HOST:-127.0.0.1}"
DNS_PORT="${DNS_PORT:-53}"
STATUS_FILE="${IPSET_STATUS_FILE:-/opt/tmp/bypass_ipset_status.json}"
APP_RUNTIME_MODE_FILE="${APP_RUNTIME_MODE_FILE:-/opt/etc/bot_app_mode}"
RUNTIME_DEDUPE_LOCK_DIR="${BYPASS_RUNTIME_DEDUPE_LOCK_DIR:-/tmp/bypass-runtime-dedupe.lock}"
RUNTIME_DEDUPE_STATE_FILE="${BYPASS_RUNTIME_DEDUPE_STATE_FILE:-/tmp/bypass-runtime-dedupe.state}"
PRIORITY_REFRESH_STATE_FILE="${BYPASS_VLESS_PRIORITY_REFRESH_STATE_FILE:-/tmp/bypass-vless-priority-refresh.state}"
UNBLOCK_IPSET_LOCK_DIR="${UNBLOCK_IPSET_LOCK_DIR:-/tmp/bypass-unblock-ipset.lock}"
UNBLOCK_IPSET_LOCK_STALE_SECONDS="${UNBLOCK_IPSET_LOCK_STALE_SECONDS:-600}"
YOUTUBE_EDGE_PREFETCH_RUNNER="${YOUTUBE_EDGE_PREFETCH_RUNNER:-/opt/etc/bot/youtube_edge_prefetch_runner.py}"
YOUTUBE_EDGE_PREFETCH_STATUS_FILE="${YOUTUBE_EDGE_PREFETCH_STATUS_FILE:-/opt/etc/bot/youtube_edge_prefetch_status.json}"
YOUTUBE_EDGE_PREFETCH_INTERVAL_SECONDS="${YOUTUBE_EDGE_PREFETCH_INTERVAL_SECONDS:-1800}"
YOUTUBE_EDGE_PREFETCH_RETRY_SECONDS="${YOUTUBE_EDGE_PREFETCH_RETRY_SECONDS:-180}"
YOUTUBE_EDGE_PREFETCH_LOG="${YOUTUBE_EDGE_PREFETCH_LOG:-/opt/var/log/bypass-youtube-edge-prefetch.log}"
VLESS_PRIORITY_DOMAINS="${VLESS_PRIORITY_DOMAINS:-remotedesktop.google.com remotedesktop-pa.googleapis.com chromoting-pa.googleapis.com chromoting-client.talkgadget.google.com instantmessaging-pa.googleapis.com instantmessaging-pa.clients6.google.com mtalk.google.com talkgadget.google.com accounts.google.com oauth2.googleapis.com www.googleapis.com apis.google.com clients2.google.com clients3.google.com clients4.google.com clients6.google.com ssl.gstatic.com www.gstatic.com fonts.googleapis.com fonts.gstatic.com www.googletagmanager.com ad.doubleclick.net googleads.g.doubleclick.net googleadservices.com pagead2.googlesyndication.com securepubads.g.doubleclick.net static.doubleclick.net youtube.com www.youtube.com youtubei.googleapis.com youtubei-att.googleapis.com jnn-pa.googleapis.com i.ytimg.com s.ytimg.com yt3.ggpht.com rutracker.org feed.rutracker.cc rutracker.wiki static.rutracker.cc}"
YOUTUBE_ROUTE_PRIORITY_DOMAINS="${YOUTUBE_ROUTE_PRIORITY_DOMAINS:-ssl.gstatic.com www.gstatic.com fonts.googleapis.com fonts.gstatic.com www.googletagmanager.com ad.doubleclick.net googleads.g.doubleclick.net googleadservices.com pagead2.googlesyndication.com securepubads.g.doubleclick.net static.doubleclick.net youtube.com www.youtube.com youtubei.googleapis.com youtubei-att.googleapis.com jnn-pa.googleapis.com i.ytimg.com s.ytimg.com yt3.ggpht.com}"
ROUTE_IPSET_SIGNATURE_SETS="${ROUTE_IPSET_SIGNATURE_SETS:-unblocksh unblockshudp unblocksh6 unblockvmess unblockvmessudp unblockvmess6 unblockvless unblockvlessudp unblockvless6 unblockvless2 unblockvless2udp unblockvless2v6 unblocktroj unblocktrojudp unblocktroj6 unblockvlesspriority unblockvlesspriority6 unblockvless2priority unblockvless2priority6}"

IPV4_RE='[0-9]{1,3}(\.[0-9]{1,3}){3}'
LOCAL_RE='localhost|^0\.|^127\.|^10\.|^172\.16\.|^192\.168\.|^::|^fc..:|^fd..:|^fe..:'

is_running() {
    [ -s "$PID_FILE" ] || return 1
    pid="$(sed -n '1p' "$PID_FILE" 2>/dev/null | tr -cd '0-9')"
    [ -n "$pid" ] || return 1
    kill -0 "$pid" 2>/dev/null
}

scheduler_pids() {
    ps w 2>/dev/null | while IFS= read -r line; do
        pid="$(printf '%s\n' "$line" | sed 's/^[[:space:]]*//;s/[[:space:]].*//')"
        case "$pid" in
            ''|PID|*[!0-9]*) continue ;;
        esac
        case "$line" in
            *"/opt/etc/init.d/S99unblock scheduler"*) printf '%s\n' "$pid" ;;
        esac
    done
}

stop_scheduler_pid() {
    target_pid="$1"
    [ -n "$target_pid" ] || return 0
    for child in $(pgrep -P "$target_pid" 2>/dev/null); do
        child_cmd="$(tr '\0' ' ' < "/proc/$child/cmdline" 2>/dev/null || true)"
        case "$child_cmd" in
            *unblock_ipset.sh*) continue ;;
        esac
        kill "$child" >/dev/null 2>&1 || true
    done
    kill "$target_pid" >/dev/null 2>&1 || true
    for _attempt in 1 2 3; do
        kill -0 "$target_pid" >/dev/null 2>&1 || return 0
        sleep 1
    done
    kill -KILL "$target_pid" >/dev/null 2>&1 || true
}

cleanup_orphan_schedulers() {
    current_pid="$(sed -n '1p' "$PID_FILE" 2>/dev/null | tr -cd '0-9')"
    for candidate_pid in $(scheduler_pids); do
        [ "$candidate_pid" = "$$" ] && continue
        [ -n "$current_pid" ] && [ "$candidate_pid" = "$current_pid" ] && continue
        stop_scheduler_pid "$candidate_pid"
    done
}

run_refresh() {
    [ -x /opt/bin/unblock_ipset.sh ] || return 0
    unblock_ipset_running && return 0
    mkdir -p "$(dirname "$LOG_FILE")" 2>/dev/null || true
    PARALLEL_JOBS="${UNBLOCK_IPSET_PARALLEL_JOBS:-4}" \
    IPV6_RESOLVE_ENABLED="${UNBLOCK_IPSET_IPV6_RESOLVE_ENABLED:-auto}" \
    UNBLOCK_IPSET_LOCK_BUSY_QUIET=1 /opt/bin/unblock_ipset.sh >> "$LOG_FILE" 2>&1 || true
    run_youtube_edge_prefetch_if_due "ipset-refresh"
}

unblock_ipset_lock_age_seconds() {
    started_at_file="$UNBLOCK_IPSET_LOCK_DIR/started_at"
    [ -s "$started_at_file" ] || {
        printf '%s\n' 0
        return
    }
    started_at="$(sed -n '1p' "$started_at_file" 2>/dev/null | tr -cd '0-9')"
    now="$(date +%s 2>/dev/null || echo 0)"
    case "$now:$started_at" in
        *[!0-9:]*|0:*|*:0) printf '%s\n' 0 ;;
        *) printf '%s\n' $((now - started_at)) ;;
    esac
}

unblock_ipset_running() {
    [ -d "$UNBLOCK_IPSET_LOCK_DIR" ] || return 1
    pid="$(sed -n '1p' "$UNBLOCK_IPSET_LOCK_DIR/pid" 2>/dev/null | tr -cd '0-9')"
    [ -n "$pid" ] || return 1
    kill -0 "$pid" 2>/dev/null || return 1
    lock_age="$(unblock_ipset_lock_age_seconds)"
    case "$lock_age:$UNBLOCK_IPSET_LOCK_STALE_SECONDS" in
        *[!0-9:]*|0:*) return 0 ;;
    esac
    [ "$lock_age" -lt "$UNBLOCK_IPSET_LOCK_STALE_SECONDS" ] 2>/dev/null
}

youtube_edge_prefetch_last_run_at() {
    [ -r "$YOUTUBE_EDGE_PREFETCH_STATUS_FILE" ] || {
        printf '%s\n' 0
        return
    }
    last_run_at="$(sed -n 's/.*"last_run_at"[[:space:]]*:[[:space:]]*\([0-9][0-9]*\).*/\1/p' "$YOUTUBE_EDGE_PREFETCH_STATUS_FILE" 2>/dev/null | head -n 1)"
    [ -n "$last_run_at" ] || last_run_at=0
    printf '%s\n' "$last_run_at"
}

youtube_edge_prefetch_skipped_reason() {
    [ -r "$YOUTUBE_EDGE_PREFETCH_STATUS_FILE" ] || {
        printf '%s\n' ""
        return
    }
    sed -n 's/.*"skipped_reason"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' "$YOUTUBE_EDGE_PREFETCH_STATUS_FILE" 2>/dev/null | head -n 1
}

youtube_edge_prefetch_due() {
    now="$(date +%s 2>/dev/null || echo 0)"
    last_run_at="$(youtube_edge_prefetch_last_run_at)"
    interval="$YOUTUBE_EDGE_PREFETCH_INTERVAL_SECONDS"
    skipped_reason="$(youtube_edge_prefetch_skipped_reason)"
    if [ "$skipped_reason" = "low_available_memory" ]; then
        interval="$YOUTUBE_EDGE_PREFETCH_RETRY_SECONDS"
    fi
    case "$now:$last_run_at:$interval" in
        *[!0-9:]*|0:*|*:0) return 0 ;;
    esac
    [ "$last_run_at" -eq 0 ] 2>/dev/null && return 0
    [ $((now - last_run_at)) -ge "$interval" ] 2>/dev/null
}

app_runtime_mode_value() {
    mode=""
    [ -r "$APP_RUNTIME_MODE_FILE" ] && mode="$(sed -n '1p' "$APP_RUNTIME_MODE_FILE" 2>/dev/null | tr -cd 'A-Za-z0-9_-')"
    [ -n "$mode" ] || mode="advanced"
    printf '%s\n' "$mode"
}

youtube_edge_prefetch_runtime_allowed() {
    [ "$(app_runtime_mode_value)" != "simple" ]
}

run_youtube_edge_prefetch() {
    trigger="${1:-scheduler}"
    youtube_edge_prefetch_runtime_allowed || return 0
    [ -f "$YOUTUBE_EDGE_PREFETCH_RUNNER" ] || return 0
    python_bin="/opt/bin/python3"
    [ -x "$python_bin" ] || python_bin="$(command -v python3 2>/dev/null || true)"
    [ -n "$python_bin" ] || return 0
    mkdir -p "$(dirname "$YOUTUBE_EDGE_PREFETCH_LOG")" 2>/dev/null || true
    PYTHONPATH="/opt/etc/bot" "$python_bin" "$YOUTUBE_EDGE_PREFETCH_RUNNER" --trigger "$trigger" >> "$YOUTUBE_EDGE_PREFETCH_LOG" 2>&1 || true
}

run_youtube_edge_prefetch_if_due() {
    youtube_edge_prefetch_due || return 0
    run_youtube_edge_prefetch "${1:-scheduler}"
}

detect_dns_backend() {
    dns_lines="$(netstat -lnptu 2>/dev/null | grep -E ':53[[:space:]]' || true)"
    if printf '%s\n' "$dns_lines" | grep -q 'dnsmasq'; then
        printf '%s\n' dnsmasq
        return
    fi
    if printf '%s\n' "$dns_lines" | grep -q 'ndnproxy'; then
        printf '%s\n' ndnproxy
        return
    fi
    if pidof dnsmasq >/dev/null 2>&1; then
        printf '%s\n' dnsmasq
        return
    fi
    if pidof ndnproxy >/dev/null 2>&1; then
        printf '%s\n' ndnproxy
        return
    fi
    printf '%s\n' unknown
}

current_refresh_interval() {
    case "$(detect_dns_backend)" in
        dnsmasq) printf '%s\n' "$DNSMASQ_INTERVAL_SECONDS" ;;
        *) printf '%s\n' "$NDNPROXY_INTERVAL_SECONDS" ;;
    esac
}

status_updated_at() {
    [ -r "$STATUS_FILE" ] || {
        printf '%s\n' 0
        return
    }
    updated_at="$(sed -n 's/.*"updated_at"[[:space:]]*:[[:space:]]*\([0-9][0-9]*\).*/\1/p' "$STATUS_FILE" 2>/dev/null | head -n 1)"
    [ -n "$updated_at" ] || updated_at=0
    printf '%s\n' "$updated_at"
}

refresh_due() {
    last_refresh="$1"
    now="$(date +%s 2>/dev/null || echo 0)"
    interval="$(current_refresh_interval)"
    case "$now:$last_refresh:$interval" in
        *[!0-9:]*|0:*|*:0) return 0 ;;
    esac
    [ "$last_refresh" -eq 0 ] 2>/dev/null && return 0
    [ $((now - last_refresh)) -ge "$interval" ] 2>/dev/null
}

run_refresh_if_due() {
    if refresh_due "$(status_updated_at)"; then
        run_refresh
    fi
}

run_refresh_if_check_due() {
    now="$(date +%s 2>/dev/null || echo 0)"
    case "$now:$last_refresh_check" in
        *[!0-9:]*|0:*) return 0 ;;
    esac
    if [ "${last_refresh_check:-0}" -eq 0 ] 2>/dev/null || [ $((now - last_refresh_check)) -ge "$REFRESH_CHECK_INTERVAL_SECONDS" ] 2>/dev/null; then
        last_refresh_check="$now"
        run_refresh_if_due
    fi
}

route_file_marker_count() {
    route_file="$1"
    shift
    [ -s "$route_file" ] || {
        printf '%s\n' 0
        return
    }
    awk '
        BEGIN {
            file_arg = ARGC - 1
            for (idx = 1; idx < file_arg; idx++) {
                markers[ARGV[idx]] = 1
                ARGV[idx] = ""
            }
        }
        {
            value = $0
            sub(/#.*/, "", value)
            gsub(/\r/, "", value)
            gsub(/^[ \t]+|[ \t]+$/, "", value)
            if (value == "") next
            sub(/^full:/, "", value)
            sub(/^domain:/, "", value)
            sub(/^\+\./, "", value)
            sub(/^\*\./, "", value)
            sub(/^\./, "", value)
            for (marker in markers) {
                suffix = "." marker
                if (value == marker || (length(value) > length(suffix) && substr(value, length(value) - length(suffix) + 1) == suffix)) {
                    count++
                    break
                }
            }
        }
        END { print count + 0 }
    ' "$@" "$route_file"
}

youtube_route_protocol() {
    youtube_markers="youtube.com www.youtube.com googlevideo.com ytimg.com youtubei.googleapis.com yt3.ggpht.com"
    best_protocol=""
    best_count=0
    for route_spec in \
        "shadowsocks:$UNBLOCK_DIR/shadowsocks.txt" \
        "vmess:$UNBLOCK_DIR/vmess.txt" \
        "vless:$UNBLOCK_DIR/vless.txt" \
        "vless2:$UNBLOCK_DIR/vless-2.txt" \
        "trojan:$UNBLOCK_DIR/trojan.txt"; do
        protocol="${route_spec%%:*}"
        route_file="${route_spec#*:}"
        count="$(route_file_marker_count "$route_file" $youtube_markers)"
        case "$count" in ''|*[!0-9]*) count=0 ;; esac
        if [ "$count" -gt "$best_count" ] 2>/dev/null; then
            best_count="$count"
            best_protocol="$protocol"
        fi
    done
    printf '%s\n' "${best_protocol:-vless}"
}

write_ipset_members() {
    set_name="$1"
    target_file="$2"
    ipset list "$set_name" 2>/dev/null | awk '
        $0 == "Members:" { members = 1; next }
        members && NF { print $1 }
    ' | sort -u > "$target_file"
}

dedupe_ipset_pair() {
    loser_set="$1"
    winner_set="$2"
    tmp_base="/tmp/bypass-runtime-dedupe.$$.$loser_set.$winner_set"
    loser_file="${tmp_base}.loser"
    winner_file="${tmp_base}.winner"
    overlap_file="${tmp_base}.overlap"

    write_ipset_members "$loser_set" "$loser_file"
    write_ipset_members "$winner_set" "$winner_file"
    awk 'NR==FNR { winner[$0] = 1; next } ($0 in winner) { print }' "$winner_file" "$loser_file" > "$overlap_file"
    while IFS= read -r entry; do
        [ -n "$entry" ] || continue
        ipset del "$loser_set" "$entry" >/dev/null 2>&1 || true
    done < "$overlap_file"
    rm -f "$loser_file" "$winner_file" "$overlap_file"
}

route_file_has_domain() {
    route_file="$1"
    target_domain="$2"
    [ -f "$route_file" ] || return 1
    awk -v target="$target_domain" '
        BEGIN { found = 0 }
        {
            value = $0
            sub(/#.*/, "", value)
            gsub(/\r/, "", value)
            gsub(/^[ \t]+|[ \t]+$/, "", value)
            if (value == "") next
            sub(/^full:/, "", value)
            sub(/^domain:/, "", value)
            sub(/^\+\./, "", value)
            sub(/^\*\./, "", value)
            sub(/^\./, "", value)
            if (value == target) {
                found = 1
                exit
            }
        }
        END { exit found ? 0 : 1 }
    ' "$route_file"
}

domain_in_list() {
    list_values="$1"
    target_domain="$2"
    for list_domain in $list_values; do
        [ "$list_domain" = "$target_domain" ] && return 0
    done
    return 1
}

resolve_priority_ipv4() {
    priority_domain="$1"
    dig +time=2 +tries=1 +short "$priority_domain" @"$DNS_HOST" -p "$DNS_PORT" 2>/dev/null \
        | grep -Eo "$IPV4_RE" \
        | grep -vE "$LOCAL_RE" \
        | sort -u
}

resolve_priority_ipv6() {
    priority_domain="$1"
    dig +time=2 +tries=1 +short AAAA "$priority_domain" @"$DNS_HOST" -p "$DNS_PORT" 2>/dev/null \
        | grep -E "^[0-9A-Fa-f:]+$" \
        | grep ":" \
        | grep -vE "$LOCAL_RE" \
        | sort -u
}

apply_vless_priority_domain_ips() {
    ipset list unblockvless >/dev/null 2>&1 || return 0
    ipset list unblockvless2 >/dev/null 2>&1 || return 0
    ipset create unblockvlesspriority hash:net -exist >/dev/null 2>&1 || true
    ipset create unblockvless2priority hash:net -exist >/dev/null 2>&1 || true
    ipset flush unblockvlesspriority >/dev/null 2>&1 || true
    ipset flush unblockvless2priority >/dev/null 2>&1 || true
    ipset create unblockvlesspriority6 hash:net family inet6 -exist >/dev/null 2>&1 || true
    ipset create unblockvless2priority6 hash:net family inet6 -exist >/dev/null 2>&1 || true
    ipset flush unblockvlesspriority6 >/dev/null 2>&1 || true
    ipset flush unblockvless2priority6 >/dev/null 2>&1 || true

    for priority_domain in $VLESS_PRIORITY_DOMAINS; do
        youtube_route="$(youtube_route_protocol)"
        force_youtube_route=0
        case "$youtube_route" in
            vless|vless2)
                domain_in_list "$YOUTUBE_ROUTE_PRIORITY_DOMAINS" "$priority_domain" && force_youtube_route=1
                ;;
        esac
        if [ "$force_youtube_route" -eq 1 ] && [ "$youtube_route" = "vless" ]; then
            winner_set="unblockvless"
            loser_set="unblockvless2"
            winner_priority_set="unblockvlesspriority"
            loser_priority_set="unblockvless2priority"
            winner6_set="unblockvless6"
            loser6_set="unblockvless2v6"
            winner_priority6_set="unblockvlesspriority6"
            loser_priority6_set="unblockvless2priority6"
        elif [ "$force_youtube_route" -eq 1 ] && [ "$youtube_route" = "vless2" ]; then
            winner_set="unblockvless2"
            loser_set="unblockvless"
            winner_priority_set="unblockvless2priority"
            loser_priority_set="unblockvlesspriority"
            winner6_set="unblockvless2v6"
            loser6_set="unblockvless6"
            winner_priority6_set="unblockvless2priority6"
            loser_priority6_set="unblockvlesspriority6"
        else
            route_file_has_domain "$UNBLOCK_DIR/vless.txt" "$priority_domain"
            in_vless=$?
            route_file_has_domain "$UNBLOCK_DIR/vless-2.txt" "$priority_domain"
            in_vless2=$?
            if [ "$in_vless" -eq 0 ] && [ "$in_vless2" -ne 0 ]; then
                winner_set="unblockvless"
                loser_set="unblockvless2"
                winner_priority_set="unblockvlesspriority"
                loser_priority_set="unblockvless2priority"
                winner6_set="unblockvless6"
                loser6_set="unblockvless2v6"
                winner_priority6_set="unblockvlesspriority6"
                loser_priority6_set="unblockvless2priority6"
            elif [ "$in_vless2" -eq 0 ] && [ "$in_vless" -ne 0 ]; then
                winner_set="unblockvless2"
                loser_set="unblockvless"
                winner_priority_set="unblockvless2priority"
                loser_priority_set="unblockvlesspriority"
                winner6_set="unblockvless2v6"
                loser6_set="unblockvless6"
                winner_priority6_set="unblockvless2priority6"
                loser_priority6_set="unblockvlesspriority6"
            else
                continue
            fi
        fi

        resolve_priority_ipv4 "$priority_domain" | while IFS= read -r priority_ip; do
            [ -n "$priority_ip" ] || continue
            ipset add "$winner_set" "$priority_ip" -exist >/dev/null 2>&1 || true
            ipset add "$winner_priority_set" "$priority_ip" -exist >/dev/null 2>&1 || true
            ipset del "$loser_set" "$priority_ip" >/dev/null 2>&1 || true
            ipset del "$loser_priority_set" "$priority_ip" >/dev/null 2>&1 || true
        done
        if ipset list "$winner6_set" >/dev/null 2>&1 && ipset list "$loser6_set" >/dev/null 2>&1; then
            resolve_priority_ipv6 "$priority_domain" | while IFS= read -r priority_ip6; do
                [ -n "$priority_ip6" ] || continue
                ipset add "$winner6_set" "$priority_ip6" -exist >/dev/null 2>&1 || true
                ipset add "$winner_priority6_set" "$priority_ip6" -exist >/dev/null 2>&1 || true
                ipset del "$loser6_set" "$priority_ip6" >/dev/null 2>&1 || true
                ipset del "$loser_priority6_set" "$priority_ip6" >/dev/null 2>&1 || true
            done
        fi
    done
}

remove_runtime_overlap_from_set() {
    loser_set="$1"
    winner_set="$2"
    [ -n "$loser_set" ] && [ -n "$winner_set" ] || return 0
    ipset list "$loser_set" >/dev/null 2>&1 || return 0
    ipset list "$winner_set" >/dev/null 2>&1 || return 0
    ipset list "$loser_set" 2>/dev/null | awk '
        /^Members:/ { members=1; next }
        members && NF { print $1 }
    ' | while IFS= read -r member; do
        [ -n "$member" ] || continue
        if ipset test "$winner_set" "$member" >/dev/null 2>&1; then
            ipset del "$loser_set" "$member" >/dev/null 2>&1 || true
        fi
    done
}

dedupe_vless_priority_overlaps() {
    case "$(youtube_route_protocol)" in
        vless2)
            remove_runtime_overlap_from_set "unblockvlesspriority" "unblockvless2"
            remove_runtime_overlap_from_set "unblockvlesspriority" "unblockvless2udp"
            remove_runtime_overlap_from_set "unblockvlesspriority6" "unblockvless2v6"
            ;;
        vless)
            remove_runtime_overlap_from_set "unblockvless2priority" "unblockvless"
            remove_runtime_overlap_from_set "unblockvless2priority" "unblockvlessudp"
            remove_runtime_overlap_from_set "unblockvless2priority6" "unblockvless6"
            ;;
        *)
            ;;
    esac
}

route_file_signature() {
    route_file="$1"
    if [ ! -f "$route_file" ]; then
        printf '%s:missing' "$route_file"
        return
    fi
    size="$(wc -c < "$route_file" 2>/dev/null | tr -cd '0-9')"
    mtime="$(stat -c %Y "$route_file" 2>/dev/null | tr -cd '0-9')"
    if [ -z "$mtime" ]; then
        mtime="$(ls -ln "$route_file" 2>/dev/null | awk '{print $5 ":" $6 ":" $7 ":" $8}')"
    fi
    printf '%s:%s:%s' "$route_file" "${size:-0}" "${mtime:-0}"
}

portable_stream_signature() {
    if command -v sha256sum >/dev/null 2>&1; then
        sha256sum 2>/dev/null | awk '{print $1}'
        return
    fi
    if command -v md5sum >/dev/null 2>&1; then
        md5sum 2>/dev/null | awk '{print $1}'
        return
    fi
    awk '
        BEGIN { count = 0; bytes = 0; first = ""; last = "" }
        {
            count += 1
            bytes += length($0)
            if (count == 1) first = $0
            last = $0
        }
        END { printf "%s:%s:%s:%s\n", count, bytes, first, last }
    '
}

ipset_members_signature() {
    set_name="$1"
    ipset list "$set_name" 2>/dev/null | awk '
        $0 == "Members:" { members = 1; next }
        members && NF { print $1 }
    ' | sort -u | portable_stream_signature
}

runtime_ipset_save_signature() {
    {
        awk -v set_list="$ROUTE_IPSET_SIGNATURE_SETS" '
            BEGIN {
                split(set_list, names, " ")
                for (idx in names) {
                    if (names[idx] != "") print "set " names[idx]
                }
            }
        '
        ipset save 2>/dev/null | awk -v set_list="$ROUTE_IPSET_SIGNATURE_SETS" '
            BEGIN {
                split(set_list, names, " ")
                for (idx in names) {
                    if (names[idx] != "") wanted[names[idx]] = 1
                }
            }
            $1 == "add" && ($2 in wanted) { print $2 " " $3 }
        '
    } | sort -u | portable_stream_signature
}

runtime_ipset_signature() {
    if command -v ipset >/dev/null 2>&1; then
        save_signature="$(runtime_ipset_save_signature)"
        if [ -n "$save_signature" ]; then
            printf '%s\n' "$save_signature"
            return
        fi
    fi
    signature=""
    for set_name in $ROUTE_IPSET_SIGNATURE_SETS; do
        signature="$signature;$set_name:$(ipset_members_signature "$set_name")"
    done
    printf '%s\n' "$signature"
}

priority_refresh_signature() {
    signature="domains=$VLESS_PRIORITY_DOMAINS"
    for route_file in "$UNBLOCK_DIR/vless.txt" "$UNBLOCK_DIR/vless-2.txt"; do
        signature="$signature;$(route_file_signature "$route_file")"
    done
    printf '%s\n' "$signature"
}

priority_refresh_due() {
    now="$(date +%s 2>/dev/null || echo 0)"
    signature="$(priority_refresh_signature)"
    last_signature=""
    last_run_at=0
    if [ -r "$PRIORITY_REFRESH_STATE_FILE" ]; then
        last_signature="$(sed -n '1p' "$PRIORITY_REFRESH_STATE_FILE" 2>/dev/null)"
        last_run_at="$(sed -n '2p' "$PRIORITY_REFRESH_STATE_FILE" 2>/dev/null | tr -cd '0-9')"
        [ -n "$last_run_at" ] || last_run_at=0
    fi
    [ -n "$signature" ] || return 0
    [ "$signature" != "$last_signature" ] && return 0
    case "$now:$last_run_at:$PRIORITY_REFRESH_INTERVAL_SECONDS" in
        *[!0-9:]*|0:*|*:0) return 0 ;;
    esac
    [ $((now - last_run_at)) -ge "$PRIORITY_REFRESH_INTERVAL_SECONDS" ] 2>/dev/null
}

mark_priority_refresh_done() {
    now="$(date +%s 2>/dev/null || echo 0)"
    signature="$(priority_refresh_signature)"
    mkdir -p "$(dirname "$PRIORITY_REFRESH_STATE_FILE")" 2>/dev/null || true
    {
        printf '%s\n' "$signature"
        printf '%s\n' "$now"
    } > "$PRIORITY_REFRESH_STATE_FILE" 2>/dev/null || true
}

runtime_dedupe_signature() {
    signature="status_updated_at=$(status_updated_at)"
    for route_file in \
        "$UNBLOCK_DIR/shadowsocks.txt" \
        "$UNBLOCK_DIR/vmess.txt" \
        "$UNBLOCK_DIR/vless.txt" \
        "$UNBLOCK_DIR/vless-2.txt" \
        "$UNBLOCK_DIR/trojan.txt"; do
        signature="$signature;$(route_file_signature "$route_file")"
    done
    signature="$signature;runtime_ipsets=$(runtime_ipset_signature)"
    printf '%s\n' "$signature"
}

runtime_dedupe_due() {
    now="$(date +%s 2>/dev/null || echo 0)"
    signature="$(runtime_dedupe_signature)"
    last_signature=""
    last_run_at=0
    if [ -r "$RUNTIME_DEDUPE_STATE_FILE" ]; then
        last_signature="$(sed -n '1p' "$RUNTIME_DEDUPE_STATE_FILE" 2>/dev/null)"
        last_run_at="$(sed -n '2p' "$RUNTIME_DEDUPE_STATE_FILE" 2>/dev/null | tr -cd '0-9')"
        [ -n "$last_run_at" ] || last_run_at=0
    fi
    [ -n "$signature" ] || return 0
    [ "$signature" != "$last_signature" ] && return 0
    case "$now:$last_run_at:$DEDUP_FORCE_INTERVAL_SECONDS" in
        *[!0-9:]*|0:*|*:0) return 0 ;;
    esac
    [ $((now - last_run_at)) -ge "$DEDUP_FORCE_INTERVAL_SECONDS" ] 2>/dev/null
}

mark_runtime_dedupe_done() {
    now="$(date +%s 2>/dev/null || echo 0)"
    signature="$(runtime_dedupe_signature)"
    mkdir -p "$(dirname "$RUNTIME_DEDUPE_STATE_FILE")" 2>/dev/null || true
    {
        printf '%s\n' "$signature"
        printf '%s\n' "$now"
    } > "$RUNTIME_DEDUPE_STATE_FILE" 2>/dev/null || true
}

apply_vless_priority_domain_ips_if_due() {
    priority_refresh_due || return 0
    apply_vless_priority_domain_ips
    dedupe_vless_priority_overlaps
    mark_priority_refresh_done
}

run_service_runtime_dedupe() {
    python_bin="/opt/bin/python3"
    [ -x "$python_bin" ] || python_bin="$(command -v python3 2>/dev/null || true)"
    [ -n "$python_bin" ] || return 0
    [ -f /opt/etc/bot/service_routes.py ] || return 0
    PYTHONPATH="/opt/etc/bot" "$python_bin" - <<'PY' || true
from service_routes import cleanup_runtime_service_route_intersections

result = cleanup_runtime_service_route_intersections()
deleted = int(result.get('deleted_members') or 0)
failed = int(result.get('failed_members') or 0)
if deleted or failed:
    print(
        'Service runtime dedupe: '
        f'{deleted} removed, {failed} failed, '
        f'{result.get("pairs", 0)} pair(s).'
    )
PY
}

dedupe_lock_pid_is_active() {
    lock_dir="$1"
    pid_file="$lock_dir/pid"
    [ -s "$pid_file" ] || return 1
    pid="$(sed -n '1p' "$pid_file" 2>/dev/null | tr -cd '0-9')"
    [ -n "$pid" ] || return 1
    kill -0 "$pid" 2>/dev/null
}

dedupe_lock_age_seconds() {
    lock_dir="$1"
    now="$(date +%s 2>/dev/null || echo 0)"
    mtime="$(stat -c %Y "$lock_dir" 2>/dev/null || echo 0)"
    case "$now:$mtime" in
        *[!0-9:]*|0:*|*:0) printf '%s\n' 0; return ;;
    esac
    if [ "$now" -gt "$mtime" ] 2>/dev/null; then
        printf '%s\n' "$((now - mtime))"
    else
        printf '%s\n' 0
    fi
}

cleanup_runtime_dedupe_lock() {
    rm -f "$RUNTIME_DEDUPE_LOCK_DIR/pid" "$RUNTIME_DEDUPE_LOCK_DIR/started_at" >/dev/null 2>&1 || true
    rmdir "$RUNTIME_DEDUPE_LOCK_DIR" >/dev/null 2>&1 || true
}

acquire_runtime_dedupe_lock() {
    if mkdir "$RUNTIME_DEDUPE_LOCK_DIR" 2>/dev/null; then
        printf '%s\n' "$$" > "$RUNTIME_DEDUPE_LOCK_DIR/pid" 2>/dev/null || true
        date +%s > "$RUNTIME_DEDUPE_LOCK_DIR/started_at" 2>/dev/null || true
        return 0
    fi

    lock_age="$(dedupe_lock_age_seconds "$RUNTIME_DEDUPE_LOCK_DIR")"
    if [ "$lock_age" -ge "$DEDUP_LOCK_STALE_SECONDS" ] 2>/dev/null && ! dedupe_lock_pid_is_active "$RUNTIME_DEDUPE_LOCK_DIR"; then
        rm -rf "$RUNTIME_DEDUPE_LOCK_DIR" >/dev/null 2>&1 || true
        if mkdir "$RUNTIME_DEDUPE_LOCK_DIR" 2>/dev/null; then
            printf '%s\n' "$$" > "$RUNTIME_DEDUPE_LOCK_DIR/pid" 2>/dev/null || true
            date +%s > "$RUNTIME_DEDUPE_LOCK_DIR/started_at" 2>/dev/null || true
            return 0
        fi
    fi
    return 1
}

run_runtime_dedupe() {
    [ "${DEDUP_INTERVAL_SECONDS:-0}" -gt 0 ] 2>/dev/null || return 0
    acquire_runtime_dedupe_lock || return 0
    trap cleanup_runtime_dedupe_lock EXIT INT TERM
    if runtime_dedupe_due; then
        run_service_runtime_dedupe
        mark_runtime_dedupe_done
    fi
    apply_vless_priority_domain_ips_if_due
    cleanup_runtime_dedupe_lock
    trap - EXIT INT TERM
}

run_scheduler_loop() {
    last_refresh_check=0
    while :; do
        run_refresh_if_check_due
        run_youtube_edge_prefetch_if_due
        run_runtime_dedupe
        sleep_seconds="$DEDUP_INTERVAL_SECONDS"
        [ "$sleep_seconds" -gt 0 ] 2>/dev/null || sleep_seconds="$INTERVAL_SECONDS"
        sleep "$sleep_seconds" &
        wait "$!" || exit 0
    done
}

start_scheduler() {
    cleanup_orphan_schedulers
    if is_running; then
        exit 0
    fi
    mkdir -p "$(dirname "$PID_FILE")" 2>/dev/null || true
    "$0" scheduler &
    echo "$!" > "$PID_FILE"
}

stop_scheduler() {
    if is_running; then
        pid="$(sed -n '1p' "$PID_FILE" 2>/dev/null | tr -cd '0-9')"
        stop_scheduler_pid "$pid"
    fi
    cleanup_orphan_schedulers
    rm -f "$PID_FILE"
}

case "$1" in
    scheduler)
        run_scheduler_loop
        ;;
    start)
        start_scheduler
        ;;
    stop)
        stop_scheduler
        ;;
    restart)
        stop_scheduler
        start_scheduler
        ;;
    refresh)
        cleanup_orphan_schedulers
        run_refresh
        run_youtube_edge_prefetch_if_due
        run_runtime_dedupe
        ;;
    status)
        if is_running; then
            echo "bypass unblock scheduler is running."
        else
            echo "bypass unblock scheduler is stopped."
            exit 1
        fi
        ;;
    *)
        echo "Usage: $0 {start|stop|restart|refresh|status}"
        exit 1
        ;;
esac
