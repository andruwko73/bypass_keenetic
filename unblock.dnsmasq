  echo "$line" | grep -Eq '[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}' && continue
  echo "ipset=/$line/$(ipset_targets "$line" unblockvless2 unblockvless2udp)" >> /opt/etc/unblock.dnsmasq
  echo "server=/$line/8.8.8.8" >> /opt/etc/unblock.dnsmasq
done < /opt/etc/unblock/vless-2.txt


while read -r line || [ -n "$line" ]; do
  line=$(normalize_line "$line")
  [ -z "$line" ] && continue
  [ "${line#\#}" != "$line" ] && continue
  echo "$line" | grep -Eq '[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}' && continue
  echo "ipset=/$line/unblocktroj" >> /opt/etc/unblock.dnsmasq
  echo "server=/$line/8.8.8.8" >> /opt/etc/unblock.dnsmasq
done < /opt/etc/unblock/trojan.txt

