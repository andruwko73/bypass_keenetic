#!/bin/sh

BOT_DIR="/opt/etc/bot"
MAIN_SCRIPT="$BOT_DIR/installer.py"
LOG_FILE="$BOT_DIR/installer.log"
ENV_FILE="$BOT_DIR/installer.env"
BOT_CONFIG_PATH="$BOT_DIR/bot_config.py"
LEGACY_CONFIG_PATH="/opt/etc/bot_config.py"

if [ -f "$ENV_FILE" ]; then
    set -a
    # shellcheck disable=SC1090
    . "$ENV_FILE"
    set +a
fi

check_process() {
    pgrep -f "python3 $MAIN_SCRIPT"
}

has_config() {
    config_path=""
    [ -f "$BOT_CONFIG_PATH" ] && config_path="$BOT_CONFIG_PATH"
    [ -z "$config_path" ] && [ -f "$LEGACY_CONFIG_PATH" ] && config_path="$LEGACY_CONFIG_PATH"
    [ -n "$config_path" ] || return 1
    grep -q "^token[[:space:]]*=" "$config_path" || return 1
    grep -q "^usernames[[:space:]]*=" "$config_path" || return 1
}

case "$1" in
    start)
        if has_config; then
            echo "Installer is not needed because bot_config.py already exists"
            exit 0
        fi

        if check_process > /dev/null; then
            echo "Installer is already running"
            exit 0
        fi

        python3 "$MAIN_SCRIPT" >> "$LOG_FILE" 2>&1 &
        pid=$!
        sleep 2

        if check_process > /dev/null; then
            echo "Installer started successfully (PID: $pid)"
            exit 0
        fi

        echo "Error: Installer failed to start"
        exit 1
        ;;
    stop)
        pid=$(check_process)
        if [ -z "$pid" ]; then
            echo "Installer is not running"
            exit 0
        fi

        kill "$pid"
        sleep 2
        if check_process > /dev/null; then
            kill -9 "$pid"
            sleep 1
        fi

        echo "Installer stopped"
        exit 0
        ;;
    restart)
        "$0" stop
        sleep 1
        "$0" start
        ;;
    status)
        if has_config; then
            echo "Installer is inactive because bot_config.py already exists"
            exit 0
        fi

        pid=$(check_process)
        if [ -n "$pid" ]; then
            echo "Installer is running (PID: $pid)"
        else
            echo "Installer is stopped"
        fi
        exit 0
        ;;
    *)
        echo "Usage: $0 {start|stop|restart|status}"
        exit 1
        ;;
esac
